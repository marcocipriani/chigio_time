rules_version = '2';

// Cloud Storage security rules.
//
// The only object family the app writes today is the profile photo, stored at
// `profile_photos/<uid>.jpg` (see ProfileRepository.uploadProfilePhoto). The
// download URL ends up in users/<uid>.photoURL and is shown in the colleague
// directory, so any signed-in user may READ a photo, but only the owner may
// WRITE their own — and only a reasonably sized image. Everything else is
// denied by default so an unmanaged bucket can never sit in "test mode".
service firebase.storage {
  match /b/{bucket}/o {
    match /profile_photos/{fileName} {
      // Readable by any authenticated user (colleague directory avatars).
      allow read: if request.auth != null;

      // Writable only by the owner: the file name must be `<uid>.jpg`, the
      // payload must be an image, and at most 5 MB. (`write` covers create,
      // update and delete in Storage rules.)
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && (request.resource == null || (
              request.resource.size < 5 * 1024 * 1024
              && request.resource.contentType.matches('image/.*')
           ));
    }

    // Default-deny: no other path is readable or writable.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
