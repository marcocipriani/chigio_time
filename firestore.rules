rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reader's own administration, used to scope the colleague directory.
    function myAdministration() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.get('administration', null)
        : null;
    }

    // Compatibilità legacy read-only: una Function già distribuita poteva
    // creare abuseBans/{uid}. Il backend corrente non crea nuovi ban, ma quelli
    // esistenti restano onorati fino a `until`; nessun match li espone al client.
    function hasActiveLegacyAbuseBan() {
      return exists(/databases/$(database)/documents/abuseBans/$(request.auth.uid))
        && get(/databases/$(database)/documents/abuseBans/$(request.auth.uid))
             .data.get('until', null) is timestamp
        && get(/databases/$(database)/documents/abuseBans/$(request.auth.uid))
             .data.get('until', null) > request.time;
    }

    // Catalogo applicativo pubblico agli utenti dell'app, ma non enumerabile
    // né modificabile dal client. La pubblicazione usa Firebase Admin.
    match /referenceData/{documentId} {
      allow get: if request.auth != null && documentId == 'pcmCatalog';
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      function profileAdministrationIsValidOnCreate() {
        let administration = request.resource.data.get('administration', null);
        return administration == null ||
          administration == 'Presidenza del Consiglio dei Ministri';
      }

      function profileAdministrationIsValidOnUpdate() {
        let oldAdministration = resource.data.get('administration', null);
        let newAdministration = request.resource.data.get(
          'administration',
          null
        );
        return (oldAdministration == null &&
            (newAdministration == null ||
              newAdministration == 'Presidenza del Consiglio dei Ministri')) ||
          (oldAdministration != null &&
            newAdministration == oldAdministration);
      }

      // Owner can always read their own profile. Other authenticated users can
      // read a profile only if they belong to the SAME administration — this is
      // the colleague directory (name, sede, phone, status, room). It stops any
      // single account from enumerating the whole user base / harvesting phone
      // numbers across administrations.
      //
      // NOTE F2: la privacy del profilo è applicata CLIENT-SIDE (la discovery
      // colleghi esclude isPrivate==true e nasconde il tasto "+"). NON è messa
      // qui come `isPrivate != true` perché renderebbe impossibili le query di
      // lista (getUsersInAdministration) e i batch `whereIn(documentId)` che
      // non filtrano per isPrivate → Firestore negherebbe l'intera query.
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (resource.data.get('administration', null) != null &&
          resource.data.get('administration', null) == myAdministration())
      );
      // `administration` scopes profile reads and cross-user writes, therefore
      // it is assigned only once. Partial pre-onboarding documents may omit it;
      // the first value supported by the product is PCM. Legacy values remain
      // immutable while their owners can still update unrelated fields.
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        profileAdministrationIsValidOnCreate();
      allow update: if request.auth != null &&
        request.auth.uid == userId &&
        profileAdministrationIsValidOnUpdate();
      // Client deletion would let a legacy account recreate the profile and
      // replace its immutable tenant field. Account erasure must be server-side.
      allow delete: if false;

      // Private, owner-only data (e.g. precise geo, sensitive settings).
      // Never exposed to other users regardless of administration.
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Effective-dated inquadramento/caps history (ADR-0009): owner only.
      match /capPeriods/{periodId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Salary credits (cedolini): owner only.
      match /salaryPayments/{paymentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /timesheets/{timesheetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Own colleagues list: managed by the owner only
      match /colleagues/{colleagueId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Notifications: owner can read/update/delete.
      // Owner can self-create (exit_reminder and similar system notifications).
      // Other authenticated users can create social notifications (coffee invites)
      // but are limited to allowed fields to prevent injection.
      match /notifications/{notifId} {
        function crossUserNotificationCommonIsValid() {
          return request.resource.data.fromUid is string &&
            request.resource.data.fromUid == request.auth.uid &&
            request.resource.data.fromName is string &&
            request.resource.data.fromName.size() > 0 &&
            request.resource.data.fromName.size() <= 60 &&
            request.resource.data.sentAt is timestamp &&
            request.resource.data.read == false;
        }

        function crossUserColleagueAddedIsValid() {
          return request.resource.data.type == 'colleague_added' &&
            request.resource.data.status == 'info' &&
            request.resource.data.keys().hasOnly([
              'type', 'fromUid', 'fromName', 'sentAt', 'status', 'read'
            ]);
        }

        function crossUserCoffeeInviteIsValid() {
          return request.resource.data.type == 'coffee_invite' &&
            request.resource.data.status == 'pending' &&
            request.resource.data.keys().hasOnly([
              'type', 'fromUid', 'fromName', 'sentAt', 'status', 'read',
              'scheduledAt'
            ]) &&
            (!('scheduledAt' in request.resource.data) ||
              (request.resource.data.scheduledAt is string &&
                request.resource.data.scheduledAt.size() <= 20));
        }

        function crossUserCoffeeAcceptedIsValid() {
          return request.resource.data.type == 'coffee_accepted' &&
            request.resource.data.status == 'info' &&
            request.resource.data.responseType in [
             'accepted', 'maybe', 'declined', 'arriving'
           ] &&
            request.resource.data.keys().hasOnly([
              'type', 'fromUid', 'fromName', 'sentAt', 'status', 'read',
              'message', 'etaMinutes', 'responseType'
            ]) &&
            (!('message' in request.resource.data) ||
              (request.resource.data.message is string &&
                request.resource.data.message.size() <= 280)) &&
            (request.resource.data.responseType == 'arriving'
              ? ('etaMinutes' in request.resource.data &&
                request.resource.data.etaMinutes is int &&
                request.resource.data.etaMinutes >= 1 &&
                request.resource.data.etaMinutes <= 60)
              : !('etaMinutes' in request.resource.data));
        }

        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && (
          request.auth.uid == userId
          || (crossUserNotificationCommonIsValid()
              // Only the social notification types may be created cross-user.
              // System notifications (exit_reminder, …) are owner-only via the
              // branch above; this stops a sender from spoofing them.
              && (crossUserColleagueAddedIsValid() ||
                crossUserCoffeeInviteIsValid() ||
                crossUserCoffeeAcceptedIsValid())
              // A3 (review 2026-07-05): solo colleghi della STESSA
              // amministrazione possono scrivere nella inbox altrui — blocca
              // spam/molestie cross-amministrazione (ogni create scatena una
              // push). Amministrazione non-null su entrambi i lati: account
              // pre-onboarding non possono né inviare né ricevere.
              && get(/databases/$(database)/documents/users/$(userId))
                   .data.get('administration', null) != null
              && get(/databases/$(database)/documents/users/$(userId))
                   .data.get('administration', null) == myAdministration()
              && !hasActiveLegacyAbuseBan()
            )
        );
      }

      // Groups: owner only
      match /groups/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Coffee log: owner only
      match /coffeeLog/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Active timer state: owner only
      match /activeTimer/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Progetti & pomodori (ADR-0011) ─────────────────────────────────────
    // Collezione top-level perché i progetti sono condivisibili tra utenti.
    match /projects/{projectId} {
      // Leggibile dai membri; i progetti condivisi sono visibili (discovery)
      // a qualunque utente autenticato.
      allow read: if request.auth != null && (
        resource.data.shared == true ||
        request.auth.uid in resource.data.memberUids
      );
      // Creazione: solo come capo progetto di sé stesso.
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && (request.auth.uid in request.resource.data.memberUids);
      // Update: il capo ha controllo pieno; un collaboratore può solo
      // unirsi/lasciare un progetto condiviso, e SOLO con il proprio uid —
      // non può espellere altri membri né aggiungerne di arbitrari.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerUid ||
        (resource.data.shared == true &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberUids']) &&
          (
            // Join: mantiene tutti i membri esistenti e aggiunge solo sé stesso.
            (request.resource.data.memberUids.hasAll(resource.data.memberUids) &&
              request.resource.data.memberUids.hasOnly(
                resource.data.memberUids.concat([request.auth.uid]))) ||
            // Leave: rimuove solo sé stesso, lascia gli altri invariati.
            (resource.data.memberUids.hasAll(request.resource.data.memberUids) &&
              resource.data.memberUids.hasOnly(
                request.resource.data.memberUids.concat([request.auth.uid])))
          ))
      );
      // Cancellazione: solo il capo progetto.
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      match /pomodoros/{pid} {
        function project() {
          return get(/databases/$(database)/documents/projects/$(projectId)).data;
        }
        // Lettura solo a membri del progetto (o se condiviso), non a chiunque.
        allow read: if request.auth != null && (
          project().shared == true ||
          request.auth.uid in project().memberUids
        );
        // Creazione: solo i propri pomodori, e solo se membro del progetto.
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && (request.auth.uid in project().memberUids);
        // Rimozione: il proprietario del pomodoro o il capo progetto.
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uid ||
          project().ownerUid == request.auth.uid
        );
        // Update consentito solo all'autore (edit pomodoro passato).
        allow update: if request.auth != null
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid;
      }
    }
  }
}
