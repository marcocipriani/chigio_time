rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Any authenticated user can read profiles (for social features: status, name, phone)
      allow read: if request.auth != null;
      // Only the owner can write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;

      match /timesheets/{timesheetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Own colleagues list: managed by the owner only
      match /colleagues/{colleagueId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Notifications: owner can read/update/delete.
      // Any authenticated user can create (send invite) but must be the sender
      // and is limited to allowed fields to prevent injection.
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.fromUid
          && request.resource.data.keys().hasOnly([
               'type', 'fromUid', 'fromName', 'sentAt', 'status',
               'read', 'scheduledAt', 'message', 'etaMinutes',
               'responseType'
             ])
          && request.resource.data.read == false;
      }

      // Groups: owner only
      match /groups/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Coffee log: owner only
      match /coffeeLog/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Active timer state: owner only
      match /activeTimer/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
